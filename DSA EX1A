#include <stdio.h>
#include <stdlib.h>

int main() {
    int N;
    scanf("%d", &N);

    int arr[N], result[N];

    
    for (int i = 0; i < N; i++) {
        scanf("%d", &arr[i]);
    }

    int left = 0;
    int right = N - 1;
    int index = N - 1;

    
    while (left <= right) {
        if (abs(arr[left]) > abs(arr[right])) {
            result[index] = arr[left] * arr[left];
            left++;
        } else {
            result[index] = arr[right] * arr[right];
            right--;
        }
        index--;
    }

    
    for (int i = 0; i < N; i++) {
        printf("%d", result[i]);
        if (i != N - 1)
            printf(" ");
    }

    return 0;
}